#!/bin/sh

# Pre-commit hook — runs before each commit.
#
# 1. Validates that all staged file names follow kebab-case convention.
# 2. Runs lint-staged to auto-fix linting and formatting on staged files.
#
# Installed by Husky. See: https://typicode.github.io/husky

# Step 1: Enforce kebab-case file names on all staged files
bash "$(dirname "$0")/../scripts/check-kebab-case.sh"

# Step 2: Run lint-staged (ESLint + Prettier for JS/TS, dart format for Flutter)
NODE_NO_WARNINGS=1 npx lint-staged
