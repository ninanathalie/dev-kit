# Sentry Environment Variables
#
# Copy the relevant variables to your project's .env file.
# Get your DSN from: https://sentry.io → Project Settings → Client Keys (DSN)
#
# Free tier: 5,000 errors/month, 1 user, 10,000 performance units

# ─── Next.js ────────────────────────────────────────────────────────────────────
# NEXT_PUBLIC_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
# SENTRY_AUTH_TOKEN=sntrys_your-auth-token-here

# ─── React (Vite) / Vue.js ──────────────────────────────────────────────────────
# VITE_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0

# ─── React Native ───────────────────────────────────────────────────────────────
# SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0

# ─── Flutter ─────────────────────────────────────────────────────────────────────
# Pass via: flutter run --dart-define=SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
# Or use flutter_dotenv: SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
