# EditorConfig — consistent coding styles across editors and IDEs.
# Supported by most editors natively or via plugins.
# See: https://editorconfig.org

# This is the top-level config; stop searching parent directories.
root = true

# Default settings for all files
[*]
charset = utf-8                   # Use UTF-8 encoding
end_of_line = lf                  # Unix-style line endings (LF, not CRLF)
indent_style = space              # Use spaces, not tabs
indent_size = 2                   # 2-space indentation
insert_final_newline = true       # Ensure files end with a newline
trim_trailing_whitespace = true   # Remove trailing whitespace on save

# Markdown — preserve trailing whitespace (used for line breaks in .md)
[*.md]
trim_trailing_whitespace = false

# YAML — explicitly set indent to 2 (YAML is whitespace-sensitive)
[*.{yml,yaml}]
indent_size = 2

# Dart — match Flutter/Dart formatter defaults
[*.dart]
indent_size = 2

# Makefiles — require tabs per Makefile syntax rules
[Makefile]
indent_style = tab
